{
  "name": "wasmito",
  "version": "1.0.0",
  "description": "",
  "type": [
    "module",
    "commonjs"
  ],
  "main": "dist/cjs/src/index.cjs",
  "exports": {
    "types": "./dist/types/src/index.d.ts",
    "import": "./dist/esm/src/index.js",
    "require": "./dist/cjs/src/index.cjs"
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist/"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "start": "tsc --watch",
    "test": "npm run build && mocha './dist/test/**/*.js' --recursive",
    "lint": "eslint . --ext .ts",
    "build": "npx tsc",
    "cli": "npm run build && LogLevel=debug node './dist/src/cli/cli.js'",
    "submodules": "bash install.sh",
    "buildforpack": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc --project tsconfig.packbuild.json --module commonjs --outDir dist/cjs && npx convert-extension cjs dist/cjs/ && rm dist/cjs/**/*.map",
    "build:esm": "tsc --project tsconfig.packbuild.json --module es6 --outDir dist/esm",
    "clean": "rm -rf dist/cjs && rm -rf dist/esm && rm -rf dist/types",
    "prepack": "npm run buildforpack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carllocos/Wasmito.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/carllocos/Wasmito/issues"
  },
  "homepage": "https://github.com/carllocos/Wasmito#readme",
  "devDependencies": {
    "@types/chai": "^4.3.6",
    "@types/figlet": "^1.5.6",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.6.1",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "chai": "^4.3.8",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard-with-typescript": "^39.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-n": "^16.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^6.1.1",
    "mocha": "^10.2.0",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "figlet": "^1.6.0",
    "portfinder": "^1.0.32",
    "serialport": "^12.0.0",
    "winston": "^3.11.0",
    "yarn": "^1.22.19"
  }
}