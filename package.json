{
  "name": "wasmito",
  "version": "1.0.0",
  "description": "",
  "type": "commonjs",
  "main": "dist/cjs/src/index.cjs",
  "exports": {
    "types": "./dist/types/src/index.d.ts",
    "import": "./dist/cjs/src/index.cjs",
    "require": "./dist/cjs/src/index.cjs"
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist/",
    ".wasmito/",
    "libs/",
    "package.json"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "start": "tsc --watch",
    "test": "npm run build:cjs && npm run compileCodeExamples && LogLevel=error mocha './dist/cjs/test/**/*.cjs' --recursive",
    "lint": "eslint . --ext .ts",
    "build": "npm run build:cjs",
    "cli": "LogLevel=error node './dist/cjs/cli/cli.cjs'",
    "test-cli": "npm run build && LogLevel=debug node './dist/cjs/cli/cli.cjs'",
    "submodules": "bash install.sh",
    "build:cjs": "rm -rf dist/cjs && tsc --project tsconfig.json && npx convert-extension cjs dist/cjs/ && npm run copyAssets",
    "build:esm": "rm -rf dist/esm  && tsc --project tsconfig-esm.json",
    "cleanNotUsed": "rm -rf dist/cjs && rm -rf dist/esm && rm -rf dist/types",
    "copyAssets": "cp -r ./src/tree-sitter/parsers/ dist/cjs/src/tree-sitter/parsers",
    "compileCodeExamples": "bash ./scripts/compile_rust_examples.sh",
    "prepack": "npm run build",
    "test-hooks": "npm run build:cjs && npm run hook:test1 && npm run hook:test2 && npm run hook:test3 && npm run hook:test4 && npm run hook:test5 && npm run hook:test6 && npm run hook:test7",
    "hook:test1": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_examples/test_isr_button/test/test_scenario.cjs",
    "hook:test2": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_around_function.cjs",
    "hook:test3": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_breakpoints.cjs",
    "hook:test4": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_hook_on_error.cjs",
    "hook:test5": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_on_event_handling_hook.cjs",
    "hook:test6": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_on_event_hook.cjs",
    "hook:test7": "LogLevel=off ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_oot.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carllocos/Wasmito.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/carllocos/Wasmito/issues"
  },
  "homepage": "https://github.com/carllocos/Wasmito#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.31.0",
    "@types/chai": "^5.2.1",
    "@types/figlet": "^1.7.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.17",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "chai": "^5.2.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-n": "^17.17.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.3.0",
    "mocha": "^11.7.2",
    "prettier": "^3.0.3",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "@webassemblyjs/wasm-parser": "^1.14.1",
    "assemblyscript": "^0.27.35",
    "commander": "^11.0.0",
    "convert-extension": "^0.3.0",
    "figlet": "^1.8.0",
    "portfinder": "^1.0.35",
    "serialport": "^13.0.0",
    "source-map": "^0.7.4",
    "uuid": "^11.1.0",
    "web-tree-sitter": "^0.25.3",
    "winston": "^3.17.0",
    "yarn": "^1.22.22"
  }
}
