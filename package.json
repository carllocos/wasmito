{
  "name": "wasmito",
  "version": "1.0.0",
  "description": "Wasmito is a library that enables the creation of language-agnostic dynamic tools (e.g., debuggers, testing tools, monitoring tools) for applications that compile to WebAssembly and that run on MCUs using the [WARDuino Wasm VM](https://github.com/carllocos/WARDuino). The **primary goal** of this project is to explore novel techniques for building language-agnostic dynamic tools tailored for MCUs. As such, this project is **highly experimental** - you can expect bugs. The tools developed using this library serve as an evaluation of the proposed techniques.",
  "type": "commonjs",
  "main": "dist/cjs/src/index.cjs",
  "exports": {
    "types": "./dist/types/src/index.d.ts",
    "import": "./dist/cjs/src/index.cjs",
    "require": "./dist/cjs/src/index.cjs"
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist/",
    ".wasmito/",
    "package.json"
  ],
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "start": "tsc --watch",
    "test": "npm run build:cjs && LogLevel=error mocha './dist/cjs/test/**/*.cjs' --recursive",
    "lint": "npx eslint .",
    "build": "npm run build:cjs",
    "cli": "LogLevel=error node './dist/cjs/cli/cli.cjs'",
    "test-cli": "npm run build && LogLevel=debug node './dist/cjs/cli/cli.cjs'",
    "submodules": "bash install.sh",
    "build:cjs": "rm -rf dist/cjs && tsc --project tsconfig.json && npx convert-extension cjs dist/cjs/ && npm run copyAssets",
    "build:esm": "rm -rf dist/esm  && tsc --project tsconfig-esm.json",
    "cleanNotUsed": "rm -rf dist/cjs && rm -rf dist/esm && rm -rf dist/types",
    "copyAssets": "cp -r ./src/tree-sitter/parsers/ dist/cjs/src/tree-sitter/parsers",
    "prepack": "npm run build",
    "test-hooks": "npm run build:cjs && npm run hook:test1 && npm run hook:test2 && npm run hook:test3 && npm run hook:test5 && npm run hook:test7",
    "hook:test1": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_examples/test_isr_button/test/test_scenario.cjs",
    "hook:test2": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_around_function.cjs",
    "hook:test3": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_breakpoints.cjs",
    "hook:test4": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_hook_on_error.cjs",
    "hook:test5": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_on_event_handling_hook.cjs",
    "hook:test6": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_on_event_hook.cjs",
    "hook:test7": "LogLevel=debug ./wasmito_tester/cli.js ./dist/cjs/wasmito_tester/test_cases/test_oot.cjs",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carllocos/Wasmito.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/carllocos/Wasmito/issues"
  },
  "homepage": "https://github.com/carllocos/Wasmito#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@types/chai": "^5.2.3",
    "@types/figlet": "^1.7.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "baseline-browser-mapping": "^2.10.13",
    "chai": "^6.2.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.4",
    "prettier": "^3.8.1",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "dependencies": {
    "@webassemblyjs/wasm-parser": "^1.14.1",
    "assemblyscript": "^0.28.9",
    "commander": "^14.0.1",
    "convert-extension": "^0.3.0",
    "csv-parser": "^3.2.0",
    "figlet": "^1.9.3",
    "portfinder": "^1.0.38",
    "serialport": "^13.0.0",
    "source-map": "^0.7.6",
    "uuid": "^13.0.0",
    "wasmito-tools": "github:aaronmunsters/wasmito-tools#pkg",
    "web-tree-sitter": "^0.25.10",
    "winston": "^3.18.3",
    "yarn": "^1.22.22"
  }
}
