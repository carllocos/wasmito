{
  "name": "wasmito",
  "version": "1.0.0",
  "description": "",
  "type": "commonjs",
  "main": "dist/cjs/src/index.cjs",
  "exports": {
    "types": "./dist/types/src/index.d.ts",
    "import": "./dist/cjs/src/index.cjs",
    "require": "./dist/cjs/src/index.cjs"
  },
  "types": "dist/types/src/index.d.ts",
  "files": [
    "dist/",
    ".wasmito/",
    "libs/",
    "package.json"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "start": "tsc --watch",
    "test": "npm run build:cjs && LogLevel=error mocha './dist/cjs/test/**/*.cjs' --recursive",
    "lint": "eslint . --ext .ts",
    "build": "npm run build:cjs",
    "cli": "npm run build && LogLevel=debug node './dist/cjs/src/cli/cli.cjs'",
    "submodules": "bash install.sh",
    "build:cjs": "rm -rf dist/cjs && tsc --project tsconfig.json && npx convert-extension cjs dist/cjs/ && npm run copyAssets && echo listing && ls ./dist/cjs/src/tree-sitter/ && ls ./dist/cjs/src/tree-sitter/parsers",
    "build:esm": "rm -rf dist/esm  && tsc --project tsconfig-esm.json",
    "cleanNotUsed": "rm -rf dist/cjs && rm -rf dist/esm && rm -rf dist/types",
    "copyAssets": "cp -r ./src/tree-sitter/parsers/ dist/cjs/src/tree-sitter/",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carllocos/Wasmito.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/carllocos/Wasmito/issues"
  },
  "homepage": "https://github.com/carllocos/Wasmito#readme",
  "devDependencies": {
    "@types/chai": "^4.3.6",
    "@types/figlet": "^1.5.6",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.6.1",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "chai": "^4.3.8",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard-with-typescript": "^39.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-n": "^16.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^6.1.1",
    "mocha": "^10.2.0",
    "prettier": "^3.0.3",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@types/uuid": "^9.0.7",
    "@webassemblyjs/wasm-parser": "^1.12.1",
    "assemblyscript": "^0.27.24",
    "commander": "^11.0.0",
    "figlet": "^1.6.0",
    "portfinder": "^1.0.32",
    "serialport": "^12.0.0",
    "source-map": "^0.7.4",
    "uuid": "^9.0.1",
    "web-tree-sitter": "^0.22.2",
    "winston": "^3.11.0",
    "yarn": "^1.22.19"
  }
}