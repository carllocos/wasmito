{
    "entries": [
        "blink.ts"
    ],
    "targets": {
        "debug": {
            "debug": true,
            "outFile": "blink.wasm",
            "textFile": "blink.wat"
        }
    },
    "options": {
        "disable": [
            "mutable-globals",
            "sign-extension",
            "nontrapping-f2i",
            "bulk-memory"
        ],
        "exportTable": true,
        "exportRuntime": false,
        "maximumMemory": 2,
        "noAssert": false,
        "runtime": "stub",
        "sourceMap": true
    }
}