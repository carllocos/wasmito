{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "esnext.asynciterable"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "./dist/cjs",
    "rootDir": "./",
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "dist/types",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "preserveConstEnums": true,
    "noEmit": false
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "tool_examples/**/*.ts",
    "cli/**/*.ts",
    "wasmito_tester/**/*.ts",
    "bench/**/*.ts"
  ],
  "exclude": ["node_modules", "test/data/assemblyscript_examples/**/*.ts"]
}
